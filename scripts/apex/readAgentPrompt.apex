ccai__AI_Agent__c a = [SELECT Id, Name, ccai__system_prompt__c, ccai__welcome_message__c, ccai__ttl_message__c, ccai__description__c, ccai__status__c FROM ccai__AI_Agent__c WHERE ccai__developer_name__c = 'Case_Resolve_Agent' LIMIT 1]; System.debug('=SYSTEM_PROMPT=' + a.ccai__system_prompt__c); System.debug('=WELCOME=' + a.ccai__welcome_message__c); System.debug('=TTL_MSG=' + a.ccai__ttl_message__c);